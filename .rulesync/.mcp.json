{
  "mcpServers": {
    "git": {
      "targets": ["*"],
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--mount",
        "type=bind,src=/Users/alex/.dotfiles,dst=/Users/alex/.dotfiles/generator",
        "mcp/git"
      ]
    },
    "typescript": {
      "targets": ["*"],
      "command": "npx",
      "args": [
        "-y",
        "@mizchi/lsmcp",
        "-p",
        "typescript",
        "--bin",
        "npx tsgo --lsp --stdio"
      ]
    },
    "context7": {
      "targets": ["*"],
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  }
}