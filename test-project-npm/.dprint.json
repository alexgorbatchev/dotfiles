{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 120,
  "indentWidth": 2,
  "useTabs": false,
  "json": {},
  "includes": ["**/*.{json,jsonc,md}"],
  "excludes": ["**/dist", "**/.generated", "**/node_modules", "**/tmp", "**/*.snap", "**/bun.lock"],
  "plugins": ["../node_modules/@dprint/json/plugin.wasm", "../node_modules/@dprint/markdown/plugin.wasm"]
}
