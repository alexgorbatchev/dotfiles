{
  "name": "dotfiles",
  "module": "cli.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "type-fest": "^5.1.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.12",
    "tslog": "^4.10.2",
    "@biomejs/biome": "^2.2.6"
  },
  "catalogs": {
    "system": {
      "@types/bun": "^1.3.0",
      "@types/node": "^24.9.1"
    },
    "testing": {
      "@rageltd/bun-test-utils": "^2.0.0",
      "express": "^5.1.0"
    },
    "typescript": {
      "@typescript/native-preview": "^7.0.0-dev.20251019.1",
      "typescript": "^5.9.3"
    }
  },
  "bin": {
    "dotfiles": "./dist/cli.js"
  },
  "scripts": {
    "lint": "biome lint",
    "typecheck": "tsgo -p tsconfig.json",
    "fmt": "biome format --write .",
    "fix": "biome check --fix .",
    "test:task": "bun test",
    "compile": "scripts/compile.ts",
    "cli": "bun run ./cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/bun": "^1.3.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^24.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20251019.1",
    "typescript": "^5.9.3"
  }
}