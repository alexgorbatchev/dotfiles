{
  "name": "dotfiles",
  "version": "1.0.6",
  "module": "cli.ts",
  "devDependencies": {
    "lefthook": "^2.0.1",
    "dts-bundle-generator": "^9.5.1",
    "@biomejs/biome": "catalog:",
    "@typescript/native-preview": "catalog:typescript"
  },
  "catalog": {
    "type-fest": "^5.1.0",
    "zod": "^4.1.12",
    "tslog": "^4.10.2",
    "@biomejs/biome": "^2.3.0"
  },
  "catalogs": {
    "system": {
      "@types/bun": "^1.3.0",
      "@types/node": "^24.9.1",
      "@types/semver": "^7.5.8"
    },
    "testing": {
      "@rageltd/bun-test-utils": "^2.0.0",
      "express": "^5.1.0"
    },
    "typescript": {
      "@typescript/native-preview": "^7.0.0-dev.20251024.1",
      "typescript": "^5.9.3"
    }
  },
  "private": true,
  "scripts": {
    "lint": "biome lint",
    "typecheck": "tsgo -p tsconfig.json",
    "fmt": "biome format --write .",
    "fix": "biome check --write --unsafe .",
    "test:task": "bun test",
    "build": "bun packages/build/src/build/index.ts",
    "version": "bun packages/build/src/version/index.ts",
    "release": "bun packages/build/src/release/index.ts",
    "publish": "bun packages/build/src/publish/index.ts",
    "release-next": "bun run version && bun run release && bun run publish",
    "test:agent": "AGENT=1 bun test",
    "cli": "bun run ./cli.ts"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
