{
  "name": "dotfiles",
  "version": "1.0.4",
  "module": "cli.ts",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "catalog:system",
    "@types/node": "catalog:system",
    "@typescript/native-preview": "catalog:typescript",
    "dts-bundle-generator": "^9.5.1",
    "lefthook": "^2.0.1",
    "typescript": "catalog:typescript"
  },
  "catalog": {
    "type-fest": "^5.1.0",
    "zod": "^4.1.12",
    "tslog": "^4.10.2",
    "@biomejs/biome": "^2.3.0"
  },
  "catalogs": {
    "system": {
      "@types/bun": "^1.3.0",
      "@types/node": "^24.9.1",
      "@types/semver": "^7.5.8"
    },
    "testing": {
      "@rageltd/bun-test-utils": "^2.0.0",
      "express": "^5.1.0"
    },
    "typescript": {
      "@typescript/native-preview": "^7.0.0-dev.20251024.1",
      "typescript": "^5.9.3"
    }
  },
  "private": true,
  "scripts": {
    "lint": "biome lint",
    "typecheck": "tsgo -p tsconfig.json",
    "fmt": "biome format --write .",
    "fix": "biome check --write --unsafe .",
    "test:task": "bun test",
    "build": "scripts/build.ts",
    "version": "scripts/version.ts",
    "release": "scripts/release.ts",
    "release-next": "bun run version && bun run release",
    "publish": "scripts/publish.ts",
    "compile": "scripts/compile.ts",
    "test:agent": "AGENT=1 bun test",
    "cli": "bun run ./cli.ts"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
