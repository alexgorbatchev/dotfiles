{
  "name": "dotfiles",
  "version": "1.0.31",
  "module": "cli.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@typescript/native-preview": "catalog:typescript",
    "tsd": "^0.33.0"
  },
  "catalog": {
    "type-fest": "^5.1.0",
    "zod": "^4.1.12",
    "tslog": "^4.10.2"
  },
  "catalogs": {
    "system": {
      "@types/bun": "^1.3.5",
      "@types/node": "^25.0.0",
      "@types/semver": "^7.5.8"
    },
    "testing": {
      "@rageltd/bun-test-utils": "^2.0.0",
      "express": "^5.1.0"
    },
    "typescript": {
      "@typescript/native-preview": "^7.0.0-dev.20251218.1",
      "typescript": "^5.9.3"
    }
  },
  "private": true,
  "scripts": {
    "lint": "biome lint",
    "typecheck": "tsgo -p tsconfig.json",
    "fmt": "biome format --write .",
    "fix": "biome check --write --unsafe .",
    "test:task": "bun test",
    "test-project": "DOTFILES_BUILT_PACKAGE_NAME='@dotfiles/core' bun run --silent cli --config test-project/config.ts",
    "build": "bun packages/build/src/build/index.ts",
    "version": "bun packages/build/src/version/index.ts",
    "release": "bun packages/build/src/release/index.ts",
    "publish": "bun packages/build/src/publish/index.ts",
    "find-unused": "bun packages/build/src/unused-analyzer/analyze.ts",
    "release-next": "bun run build && bun run version && bun run release && bun run publish",
    "test:agent": "AGENT=1 bun test",
    "cli": "bun run ./cli.ts",
    "check": "bun lint && bun typecheck && bun test"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
