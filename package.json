{
  "name": "generator",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "mydotfiles": "./dist/cli.js"
  },
  "scripts": {
    "test": "bun run src/testing-helpers/bun-test-runner.ts",
    "lint": "tsgo -p tsconfig.json && biome check ./src",
    "fmt": "biome format --write .",
    "fix": "biome check --fix .",
    "test:task": "BUN_CORRECT_TEST_COMMAND=1 bun test",
