{
  "compilerOptions": {
    // "DOM" for fetch API types like HeadersInit, Response
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "esModuleInterop": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitAny": true,
  },
  "include": ["packages", "test-project", "cli.ts"],
  "exclude": [
    "**/.tmp/**",
    "packages/**/type-tests/**",
    "packages/**/__tests__/**/tool-types.d.ts",
  ]
}
