{
  "compilerOptions": {
    // "DOM" for fetch API types like HeadersInit, Response
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "esModuleInterop": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitAny": true,

    // Path mappings for test-project
    "paths": {
      "@gitea/dotfiles": ["./packages/cli/src/index.ts"],
      "@dotfiles/core": ["./packages/core/src/index.ts"]
    }
  },
  "include": ["packages", "test-project", "cli.ts"],
  "exclude": [
    "**/.tmp/**",
    "packages/**/type-tests/**",
    "packages/**/__tests__/**/tool-types.d.ts",
    "packages/core/src/__tests__/InstallerPluginRegistry--typescript-integration.test.ts"
  ]
}
