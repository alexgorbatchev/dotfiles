{
  "editor.formatOnSave": false,
  "eslint.enable": false,
  "prettier.enable": false,

  "search.exclude": {
    "**/dist": true,
    "**/.generated": true,
    "**/node_modules": true
  },

  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/bun.lock": true
  },
  "peacock.color": "#632399",

  "bun.test.customScript": "bun test:agent",
  "bun.test.customFlag": "",
  "testing.coverageToolbarEnabled": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "biome.lsp.bin": "./node_modules/.bin/biome",

  "todo-tree.filtering.includeGlobs": ["**/packages/**"],
  "todo-tree.filtering.excludeGlobs": ["**/node_modules/**", "**/README.md"],
  "todo-tree.tree.autoRefresh": false,
}
