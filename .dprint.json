{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 120,
  "indentWidth": 2,
  "useTabs": false,
  "typescript": {
    "semiColons": "always",
    "quoteStyle": "preferSingle",
    "trailingCommas": "onlyMultiLine",
    "useBraces": "maintain",
    "bracePosition": "sameLineUnlessHanging",
    "singleBodyPosition": "maintain",
    "nextControlFlowPosition": "sameLine",
    "operatorPosition": "maintain",
    "preferHanging": false,
    "preferSingleLine": false,
    "arrowFunction.useParentheses": "force"
  },
  "json": {},
  "includes": ["**/*.{ts,tsx,js,jsx,json,jsonc,md}"],
  "excludes": ["**/dist", "**/.generated", "**/node_modules", "**/tmp", "**/*.snap", "**/bun.lock"],
  "plugins": [
    "./node_modules/@dprint/typescript/plugin.wasm",
    "./node_modules/@dprint/json/plugin.wasm",
    "./node_modules/@dprint/markdown/plugin.wasm"
  ]
}
