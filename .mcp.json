{
  "mcpServers": [
    {
      "name": "git",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--mount",
        "type=bind,src=/Users/alex/.dotfiles,dst=/Users/alex/.dotfiles/generator",
        "mcp/git"
      ]
    },
    {
      "name": "typescript",
      "command": "npx",
      "args": ["-y", "@mizchi/lsmcp", "-p", "typescript", "--bin", "npx tsgo --lsp --stdio"]
    },
    {
      "name": "context7",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  ]
}
