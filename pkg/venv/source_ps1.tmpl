# ==============================================================================
# Dotfiles Virtual Environment Activation Script (PowerShell)
# ==============================================================================
# This file is automatically generated. Do not edit directly.
#
# Usage:
#   . .\{{.EnvName}}\source.ps1
#   . {{.EnvName}}/source.ps1
#
# To deactivate:
#   dotfiles-deactivate
# ==============================================================================

function global:dotfiles-deactivate {
  if ($env:_DOTFILES_ENV_DIR) {
    if ($env:_DOTFILES_OLD_XDG_CONFIG_HOME) {
      $env:XDG_CONFIG_HOME = $env:_DOTFILES_OLD_XDG_CONFIG_HOME
      Remove-Item Env:_DOTFILES_OLD_XDG_CONFIG_HOME -ErrorAction SilentlyContinue
    } else {
      Remove-Item Env:XDG_CONFIG_HOME -ErrorAction SilentlyContinue
    }
    Remove-Item Env:_DOTFILES_ENV_DIR -ErrorAction SilentlyContinue
    Remove-Item Env:_DOTFILES_ENV_NAME -ErrorAction SilentlyContinue
    Remove-Item function:dotfiles-deactivate -ErrorAction SilentlyContinue
  }
}

$scriptPath = $MyInvocation.MyCommand.Path
$targetDir = ""
if ($scriptPath) {
  $targetDir = Split-Path -Parent $scriptPath
} else {
  $targetDir = "{{.EnvDir}}"
}

if ($env:_DOTFILES_ENV_DIR) {
  dotfiles-deactivate
}

if ($env:XDG_CONFIG_HOME) {
  $env:_DOTFILES_OLD_XDG_CONFIG_HOME = $env:XDG_CONFIG_HOME
}

$env:_DOTFILES_ENV_DIR = $targetDir
$env:_DOTFILES_ENV_NAME = "{{.EnvName}}"
$env:XDG_CONFIG_HOME = "$targetDir\.config"

Write-Host "Activated dotfiles environment: {{.EnvName}}"
Write-Host "  Directory: $env:_DOTFILES_ENV_DIR"
Write-Host "  Config: $env:_DOTFILES_ENV_DIR\dotfiles.config.ts"
